# ── Green API credentials ──────────────────────────────────────────────────────
# From https://console.green-api.com → your instance
GREEN_API_ID_INSTANCE=1101000000
GREEN_API_TOKEN=your_token_here

# Base URL — copy from your console (may differ by region/plan)
GREEN_API_URL=https://api.greenapi.com

# ── Rasa ───────────────────────────────────────────────────────────────────────
RASA_WEBHOOK_URL=https://your-rasa-app.up.railway.app/webhooks/rest/webhook

# ── Webhook registration ───────────────────────────────────────────────────────
# Public URL of THIS service (Railway gives you one automatically).
# Set this and the bridge will auto-register the webhook with Green API on startup.
# e.g. https://whatsapp-greenapi-rasa-bridge.up.railway.app
PUBLIC_URL=https://your-bridge.up.railway.app

# Optional: secret token to validate incoming webhooks (recommended)
# Set the same value in Green API console → webhookUrlToken
WEBHOOK_TOKEN=your_secret_token

# ── Bot identity ───────────────────────────────────────────────────────────────
# Phone number of this instance (digits only, with country code, no +)
# Used to detect @mentions in group messages
BOT_PHONE_NUMBER=447911123456

# ── Response trigger ───────────────────────────────────────────────────────────
# mention  → only respond when @mentioned (recommended)
# keyword  → only when message contains BOT_KEYWORD
# all      → every group message
GROUP_TRIGGER_MODE=mention

BOT_KEYWORD=!bot

# ── Group filter ───────────────────────────────────────────────────────────────
# Comma-separated chatIds to listen on. Leave blank for ALL groups.
# Run: npm run list-groups  to get your group chatIds
ALLOWED_GROUP_IDS=

# ── Scope ──────────────────────────────────────────────────────────────────────
HANDLE_GROUP_MESSAGES=true
HANDLE_DM_MESSAGES=false

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
